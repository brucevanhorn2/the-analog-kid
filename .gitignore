# =============================================================================
# The Analog Kid — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# RenPy compiled bytecode (regenerated automatically on launch)
# -----------------------------------------------------------------------------
*.rpyc
*.rpycm

# -----------------------------------------------------------------------------
# RenPy runtime directories
# -----------------------------------------------------------------------------
game/saves/
game/cache/
game/tmp/

# -----------------------------------------------------------------------------
# RenPy log files (written at runtime to project root and game/)
# -----------------------------------------------------------------------------
log.txt
traceback.txt
errors.txt
game/log.txt
game/traceback.txt

# -----------------------------------------------------------------------------
# RenPy distribution files (if the SDK ever lands here — do not commit it)
# -----------------------------------------------------------------------------
renpy/
lib/

# -----------------------------------------------------------------------------
# Source assets
# High-res Daz renders in source_assets/images_2560x1440/ are excluded —
# they can be large and are not needed to run the game.
# If you want to track them, use Git LFS: git lfs track "*.png"
# -----------------------------------------------------------------------------
source_assets/images_2560x1440/

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# -----------------------------------------------------------------------------
# Editor and IDE files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.py[cod]
